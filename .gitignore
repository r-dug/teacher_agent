# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# notes
# .notes/

# Secrets
.env
.env_vars
.env.local
.env.*.local
.certbot_email
# TLS certificates (machine-specific, generated locally)
certs/

# VAD static assets — large binaries, regenerated from node_modules after npm install
# Run: npm run copy-vad-assets  (defined in client/package.json)
client/public/vad/*.wasm
client/public/vad/*.onnx
client/public/vad/ort.min.js
client/public/vad/vad.bundle.min.js
client/public/vad/*.mjs

# Local SQLite runtime data
storage/*.sqlite3
storage/*.sqlite3-*
